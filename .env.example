# Copy to .env and adjust. Do NOT commit the real .env (it is git-ignored).

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=tickettracker
# Host port Postgres is published on, for tools outside Docker (e.g. running the
# app from Visual Studio, which connects to localhost:5432 per appsettings.Development.json).
DB_PORT=5432

# --- Backend / ASP.NET Core ---
ASPNETCORE_ENVIRONMENT=Production

# --- JWT ---
# Use a long, random value in any shared or production environment (>= 32 bytes).
JWT_ISSUER=TicketTracker
JWT_AUDIENCE=TicketTracker
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-bytes-long

# --- SMTP (email verification) ---
# Defaults target the bundled Mailpit sink (web UI at http://localhost:${MAIL_WEB_PORT}).
# For real mail, set SMTP_HOST=relay1.dataart.com (and port/credentials as required).
SMTP_HOST=mail
SMTP_PORT=1025
SMTP_USE_STARTTLS=false
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@tickettracker.local
SMTP_FROM_NAME=Ticket Tracker
MAIL_WEB_PORT=8025

# --- Frontend ---
# Host port the SPA is published on: http://localhost:${WEB_PORT}
WEB_PORT=8080

# Base URL used in verification links (defaults to http://localhost:${WEB_PORT}).
APP_CLIENT_URL=http://localhost:8080
